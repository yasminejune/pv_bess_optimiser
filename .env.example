# Weather API Configuration
WEATHER_API_KEY=your_api_key_here
WEATHER_API_URL=https://api.weather.example.com/v1
WEATHER_API_TIMEOUT=30

# Price API Configuration
PRICE_API_KEY=your_api_key_here
PRICE_API_URL=https://api.price.example.com/v1
PRICE_API_TIMEOUT=30

# Application Configuration
LOG_LEVEL=INFO
ENVIRONMENT=development

# Battery Configuration
BATTERY_CAPACITY_KWH=100.0
BATTERY_MAX_CHARGE_KW=50.0
BATTERY_MAX_DISCHARGE_KW=50.0
BATTERY_EFFICIENCY_CHARGE=0.95
BATTERY_EFFICIENCY_DISCHARGE=0.95

# PV Configuration
PV_CAPACITY_KW=100.0

# Simulation Configuration
SIMULATION_START_DATE=2024-01-01T00:00:00
SIMULATION_TIMESTEP_MINUTES=15
